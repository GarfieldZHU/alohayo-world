{
  "name": "alohayo-world",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.17.1+sha512.ccbfabf7d7b6b32075088be9386fb9a2e00bb6887ef07fa56effabc890a56d53da1ccc4128d62db245fcbd3961b236d75335bdf7d5320ed6eafb7588b7ad4697",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --config apps/game/vite.config.ts",
    "preview": "vite preview --config apps/game/vite.config.ts",
    "build": "vite build --config apps/game/vite.config.ts && yarn build:wasm && node scripts/package-release.mjs",
    "build:e2e": "vite build --mode test --config apps/game/vite.config.ts && yarn build:wasm",
    "build:wasm": "node scripts/build-wasm.mjs",
    "verify:wasm": "REQUIRE_WASM=1 yarn build:wasm",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "validate:content": "node scripts/validate-content.mjs",
    "validate:assets": "node scripts/validate-assets.mjs",
    "benchmark": "vitest run tests/benchmarks",
    "check:perf": "node scripts/check-performance-budgets.mjs",
    "package": "node scripts/package-release.mjs"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "pixi.js": "^8.9.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.15.29",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^7.3.6",
    "vitest": "^3.2.7"
  }
}
